{
  "name": "kerykeion-ts",
  "type": "module",
  "version": "5.12.7-ts.4",
  "packageManager": "bun@1.3.11",
  "description": "TypeScript core port of kerykeion with source-built Swiss Ephemeris WASM.",
  "license": "AGPL-3.0-only",
  "keywords": [
    "astrology",
    "bun",
    "kerykeion",
    "serverless",
    "svg",
    "swisseph",
    "wasm"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.js",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./node": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "browser": "./dist/browser.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "assets/sweph",
    "dist"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist .tmp .tmp-report-compare build patches tmp-*.svg",
    "build:chart-assets": "bun run scripts/generate-chart-assets.mjs",
    "build:sweph-constants": "bun run scripts/generate-sweph-constants.mjs",
    "build:sweph-wasm": "./scripts/build-sweph-wasm.sh",
    "build:js": "vite build",
    "build:dist-runtime": "node ./scripts/fix-vite-dist-runtime.mjs",
    "build:types": "tsc -p tsconfig.types.json",
    "build": "bun run clean && bun run build:chart-assets && bun run build:sweph-constants && bun run build:sweph-wasm && bun run build:js && bun run build:dist-runtime && bun run build:types",
    "browser:check": "node ./scripts/browser-check.mjs",
    "check:unused": "knip --include files,dependencies --no-progress",
    "demo:web": "bun run scripts/start-browser-demo.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "refresh:report-fixtures": "bun run scripts/refresh-report-fixtures.mjs",
    "sync:vendors": "bun run scripts/sync-vendors.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "bun run lint && bun run typecheck && bun run check:unused && bun run browser:check",
    "verify:full": "bun run verify && bun run test",
    "prepublishOnly": "bun run build && bun run verify"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "knip": "^6.4.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
