{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "allowImportingTsExtensions": false,
    "allowJs": false,
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "./dist"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ]
}
